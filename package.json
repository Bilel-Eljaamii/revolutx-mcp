{
  "name": "revolutx-mcp",
  "version": "1.0.0",
  "description": "Revolut X Crypto Exchange MCP Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npx tsc",
    "dev": "npx tsc && node dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "npx tsc --noEmit",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix",
    "format": "npx prettier --write \"src/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "rebuild": "rm -rf dist && npx tsc",
    "test": "npx jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "axios": "1.14.0",
    "dotenv": "17.4.1"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "25.5.2",
    "@eslint/js": "^9.20.0",
    "eslint": "9.20.0",
    "eslint-plugin-security": "4.0.0",
    "jest": "30.3.0",
    "prettier": "3.5.3",
    "ts-jest": "29.4.9",
    "typescript": "5.8.2",
    "typescript-eslint": "8.33.0"
  }
}

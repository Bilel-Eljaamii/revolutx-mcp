# Your Revolut X API Key (64-character alphanumeric string)
REVOLUTX_API_KEY=your_api_key_here

# Your Ed25519 Private Key for request signing
# You can provide the raw base64 string or the full PEM format
REVOLUTX_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_base64_private_key_here\n-----END PRIVATE KEY-----"
